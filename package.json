{
  "name": "eventreels-e2e",
  "version": "1.0.0",
  "description": "Standalone Playwright E2E test suite for EventReels",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test --project=auth",
    "test:e2e": "playwright test --project=e2e",
    "test:headed": "playwright test --project=e2e --headed",
    "test:ui": "playwright test --project=e2e --ui",
    "test:report": "playwright show-report",
    "setup": "playwright test --project=setup"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "exceljs": "^4.4.0",
    "googleapis": "^140.0.1",
    "typescript": "^5.9.3"
  }
}
